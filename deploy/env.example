# الگوی /opt/bourssanj-site/.env روی سرور ایران — مقادیر واقعی را از Environment سرویس Render کپی کن.
# دقت: NEXT_PUBLIC_* در بیلد inline می‌شوند، پس موقع بیلد روی مک هم باید در .env.local باشند.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# فقط سرور — هرگز NEXT_PUBLIC نشود
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

BRSAPI_KEY=
NEXT_PUBLIC_BRSAPI_KEY=

GEMINI_API_KEY=
OPENROUTER_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# OPENROUTER_MODEL=google/gemini-3.1-flash-lite

# ⚠️ مخصوص سرور ایران: گوگل/OpenRouter آی‌پی ایران را بلاک می‌کنند و تلگرام داخل ایران فیلتر است.
# این سه relay روی سرور آلمان (Apache همان دامنه‌ی بات) ست می‌شوند. روی Render این سه را نگذار.
GEMINI_BASE_URL=https://newbot.dadashchekhabare.qzz.io/relay/gemini
OPENROUTER_BASE_URL=https://newbot.dadashchekhabare.qzz.io/relay/openrouter
TELEGRAM_BASE_URL=https://newbot.dadashchekhabare.qzz.io/relay/telegram

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PORTFOLIO_BOT_TOKEN=

SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=838135

ADMIN_EMAIL=

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
